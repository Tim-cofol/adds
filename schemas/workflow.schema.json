{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "hermes-workflow-v1",
  "title": "Hermes Workflow Template",
  "type": "object",
  "required": ["id", "version", "inputs", "entry", "nodes"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "description": { "type": "string" },
    "inputs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "type": "string", "enum": ["string", "path", "integer", "boolean"] },
          "required": { "type": "boolean", "default": true },
          "default": {},
          "description": { "type": "string" }
        }
      }
    },
    "runtime": {
      "type": "object",
      "properties": {
        "board": { "type": "string" },
        "tenant": { "type": "string" },
        "idempotency": {
          "type": "object",
          "properties": {
            "strategy": { "type": "string" }
          }
        }
      }
    },
    "entry": {
      "type": "object",
      "required": ["assignee"],
      "properties": {
        "assignee": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "assignee", "body"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string" },
          "assignee": { "type": "string" },
          "parents": { "type": "array", "items": { "type": "string" } },
          "skills": { "type": "array", "items": { "type": "string" } },
          "workspace": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string", "enum": ["scratch", "dir", "worktree"] },
              "repo": { "type": "string" },
              "base": { "type": "string" },
              "branch": { "type": "string" },
              "path": { "type": "string" },
              "clean_required": { "type": "boolean" },
              "preserve_after_done": { "type": "boolean" }
            }
          },
          "body": { "type": "string" },
          "output_contract": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "required": { "type": "array", "items": { "type": "string" } },
              "properties": { "type": "object" }
            }
          },
          "mode": { "type": "string", "enum": ["auto", "manual_gate", "auto_decompose"] },
          "manual_gate": {
            "type": "object",
            "properties": {
              "approvers": { "type": "array", "items": { "type": "string" } },
              "approval_actions": { "type": "array" },
              "timeout": { "type": "string" },
              "on_timeout": { "type": "string" }
            }
          },
          "review_policy": {
            "type": "object",
            "properties": {
              "pass_values": { "type": "array", "items": { "type": "string" } },
              "fail_behavior": { "type": "object" }
            }
          },
          "task_size_limit": {
            "type": "object",
            "properties": {
              "changed_lines_hint": { "type": "integer" }
            }
          }
        }
      }
    }
  }
}
